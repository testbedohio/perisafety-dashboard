# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Bearer token for the n8n MCP server at testbed999.app.n8n.cloud/mcp-server/http
# Find it in n8n under Settings → MCP or the Header Auth credential used by your workflows.
N8N_MCP_TOKEN=your-n8n-mcp-token-here

PORT=3001
